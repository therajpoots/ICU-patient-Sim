# ============================================================
#  ICU Biosignal Pipeline - Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# --- API Security ---
# The shared secret used to derive the AES-256 encryption key.
# Change this to a long, random string (32+ characters).
AES_SHARED_SECRET=change-me-to-a-very-long-random-secret-string-here

# API key that clients must send in the X-API-Key header
API_KEY=icu-monitor-dev-key-change-in-production

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8443
USE_TLS=true

# --- Simulation Settings ---
# Patient ID (used in reports)
PATIENT_ID=ICU-2026-001
PATIENT_NAME=John Doe
PATIENT_AGE=67
PATIENT_WARD=NICU-3B

# Simulation speed (1.0 = real-time, 2.0 = 2x faster for testing)
SIM_SPEED=1.0

# Sampling rate for waveforms (Hz)
SAMPLING_RATE=250

# How many seconds of waveform to keep in memory per signal
WAVEFORM_BUFFER_SECONDS=30

# --- Arrhythmia Settings ---
# Mean time between episodes (seconds). Default: 9000s ≈ 2.5 hours
ARRHYTHMIA_MEAN_INTERVAL_S=9000

# --- Database ---
DB_PATH=data/icu_monitor.db

# --- Report Output ---
REPORT_OUTPUT_DIR=data/reports
